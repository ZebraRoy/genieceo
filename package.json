{
  "name": "genieceo",
  "version": "0.1.22",
  "description": "GenieCEO: a self-growing agent CLI with a local workspace",
  "type": "module",
  "packageManager": "pnpm@10.28.2",
  "bin": {
    "genieceo": "dist/cli.js"
  },
  "files": [
    "dist",
    "docs",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-templates.mjs",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.1",
    "@mariozechner/pi-ai": "latest",
    "@sinclair/typebox": "^0.34.41",
    "cheerio": "^1.1.2",
    "commander": "^14.0.0",
    "html-to-text": "^9.0.5",
    "yaml": "^2.8.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
